          ],
          "explanation": "Do you live in a big city?"
        },
        {
          "id": "exercise-5-6",
          "type": "translate",
          "prompt": "Она работает в компании?",
          "answers": [
            "Does she work for a company",
            "Does she work in a company"
          ],
          "explanation": "Does she work for a company? После Does: work."
        },
        {
          "id": "exercise-5-7",
          "type": "translate",
          "prompt": "Этот билет стоит двадцать евро.",
          "answers": [
            "This ticket costs twenty euros"
          ],
          "explanation": "This ticket costs twenty euros. This ticket = it, поэтому costs."
        },
        {
          "id": "exercise-5-8",
          "type": "translate",
          "prompt": "В этой компании работает сто человек.",
          "answers": [
            "One hundred people work for this company",
            "A hundred people work for this company",
            "One hundred people work at this company",
            "A hundred people work at this company"
          ],
          "explanation": "One hundred people work for this company. People = they, поэтому work."
        }
      ]
    }
