    {
      "type": "section",
      "title": "Часть 2. Present Simple",
      "text": "Используйте обычную форму глагола, а после he, she и it не забывайте окончание."
    },
    {
      "type": "exercise",
      "id": "exercise-3",
      "title": "Задание 3. Выберите правильную форму глагола",
      "instruction": "Выберите вариант, который подходит к подлежащему.",
      "items": [
        {
          "id": "exercise-3-1",
          "type": "single",
          "prompt": "I ___ in an office.",
          "options": [
            "work",
            "works",
            "working"
          ],
          "answer": "work",
          "explanation": "После I используем базовую форму: work."
        },
        {
          "id": "exercise-3-2",
          "type": "single",
          "prompt": "She ___ at nine o'clock.",
          "options": [
            "start",
            "starts",
            "starting"
          ],
          "answer": "starts",
          "explanation": "После she добавляем -s: starts."
        },
        {
          "id": "exercise-3-3",
          "type": "single",
          "prompt": "We ___ near the city centre.",
          "options": [
            "lives",
            "live",
            "living"
          ],
          "answer": "live",
          "explanation": "После we используем базовую форму: live."
        },
        {
          "id": "exercise-3-4",
          "type": "single",
          "prompt": "My brother ___ English every day.",
          "options": [
            "study",
            "studys",
            "studies"
          ],
          "answer": "studies",
          "explanation": "После согласной + y: study → studies."
        },
        {
          "id": "exercise-3-5",
          "type": "single",
          "prompt": "Anna ___ to work by bus.",
          "options": [
            "go",
            "goes",
            "gos"
          ],
          "answer": "goes",
          "explanation": "Глагол go после she получает -es: goes."
        },
        {
          "id": "exercise-3-6",
          "type": "single",
          "prompt": "They ___ coffee in the morning.",
          "options": [
            "drinks",
            "drink",
            "drinking"
          ],
          "answer": "drink",
          "explanation": "После they используем базовую форму: drink."
        },
        {
          "id": "exercise-3-7",
          "type": "single",
          "prompt": "The shop ___ at ten.",
          "options": [
            "open",
            "opens",
            "opening"
          ],
          "answer": "opens",
          "explanation": "The shop = it, поэтому opens."
        },
        {
          "id": "exercise-3-8",
          "type": "single",
          "prompt": "My parents ___ in a small town.",
          "options": [
            "lives",
            "live",
            "is live"
          ],
          "answer": "live",
          "explanation": "My parents = they, поэтому live."
        }
      ]
    },
    {
      "type": "exercise",
      "id": "exercise-4",
      "title": "Задание 4. Отрицания и вопросы",
      "instruction": "Выберите грамматически правильное предложение.",
      "items": [
        {
          "id": "exercise-4-1",
          "type": "single",
          "prompt": "Я не работаю по субботам.",
          "options": [
            "I don't work on Saturdays.",
            "I doesn't work on Saturdays.",
            "I not work on Saturdays."
          ],
          "answer": "I don't work on Saturdays.",
          "explanation": "После I используем don't + базовую форму work."
        },
        {
          "id": "exercise-4-2",
          "type": "single",
          "prompt": "Она не пьёт чай.",
          "options": [
            "She don't drink tea.",
            "She doesn't drinks tea.",
            "She doesn't drink tea."
          ],
          "answer": "She doesn't drink tea.",
          "explanation": "После doesn't глагол остаётся в базовой форме: drink."
        },
        {
          "id": "exercise-4-3",
          "type": "single",
          "prompt": "Ты живёшь здесь?",
          "options": [
            "Do you live here?",
            "Does you live here?",
            "You do live here?"
          ],
          "answer": "Do you live here?",
          "explanation": "Вопрос с you начинается с Do."
        },
        {
          "id": "exercise-4-4",
          "type": "single",
          "prompt": "Он работает дома?",
          "options": [
            "Do he work at home?",
            "Does he work at home?",
            "Does he works at home?"
          ],
          "answer": "Does he work at home?",
          "explanation": "После Does используем базовую форму work."
        },
        {
          "id": "exercise-4-5",
          "type": "single",
          "prompt": "Мы не начинаем в восемь.",
          "options": [
            "We don't start at eight.",
            "We doesn't start at eight.",
            "We don't starts at eight."
          ],
          "answer": "We don't start at eight.",
          "explanation": "После we: don't start."
        },
        {
          "id": "exercise-4-6",
          "type": "single",
          "prompt": "Мария говорит по-английски?",
          "options": [
            "Do Maria speak English?",
            "Does Maria speaks English?",
            "Does Maria speak English?"
          ],
          "answer": "Does Maria speak English?",
          "explanation": "Maria = she: Does Maria speak...?"
        },
        {
          "id": "exercise-4-7",
          "type": "single",
          "prompt": "Они не живут в Лондоне.",
          "options": [
            "They don't live in London.",
            "They doesn't live in London.",
            "They don't lives in London."
          ],
          "answer": "They don't live in London.",
          "explanation": "После they используем don't live."
        },
        {
          "id": "exercise-4-8",
          "type": "single",
          "prompt": "Магазин открывается в девять?",
          "options": [
            "Do the shop open at nine?",
            "Does the shop open at nine?",
            "Does the shop opens at nine?"
          ],
          "answer": "Does the shop open at nine?",
          "explanation": "The shop = it: Does the shop open...?"
        }
      ]
    },
    {
      "type": "exercise",
      "id": "exercise-5",
      "title": "Задание 5. Переведите предложения",
